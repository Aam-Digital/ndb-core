{
  "servers": {
    "angular-cli": {
      "command": "npx",
      "args": [
        "-y",
        "@angular/cli",
        "mcp"
      ]
    },
    "sentry": {
      "command": "npx",
      "args": [
        "-y",
        "@sentry/mcp-server",
        "--organization-slug",
        "aam-digital"
      ],
      "env": {
        "SENTRY_ACCESS_TOKEN": "${input:sentryAuthToken}"
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ]
    }
  },
  "inputs": [
    {
      "id": "sentryAuthToken",
      "type": "promptString",
      "description": "Sentry Auth Token",
      "password": true
    }
  ]
}
